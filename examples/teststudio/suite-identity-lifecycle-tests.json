  "cases": [
    {
      "id": "happy-internal-full",
      "name": "Full Hire – Intern mit Primary, Secondary, Admin und Test",
      "seed": 101,
      "steps": [
        {
          "type": "employee.created",
          "subject": "/employees/E-2026-001",
          "data": {
            "firstName": "Max",
            "lastName": "Muster",
            "department": "Engineering",
            "type": "internal"
          }
        },
        {
          "type": "primary-account.assigned",
          "data": {
            "primaryAccountId": "PUA-2026-001",
            "username": "mmuster",
            "status": "active"
          }
        },
        {
          "type": "secondary-account.linked",
          "data": {
            "secondaryAccountId": "SUA-2026-001",
            "ownerPrimaryAccountId": "PUA-2026-001",
            "purpose": "shared-inbox"
          }
        },
        {
          "type": "admin-account.assigned",
          "data": {
            "adminAccountId": "ADM-2026-001",
            "level": "super"
          }
        },
        {
          "type": "test-account.assigned",
          "data": {
            "testAccountId": "TST-2026-001",
            "scope": "integration",
            "expiryDate": "2026-12-31T00:00:00Z"
          }
        },
        {
          "type": "employee.offboarded",
          "data": {
            "reason": "Befoerderung in anderes Unternehmen"
          }
        }
      ],
      "expect": {
        "outcome": "accept",
        "endState": "archived"
      }
    },
